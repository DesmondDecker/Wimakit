# ─────────────────────────────────────────────────────────────────────────────
# WimaKit Web (Expo) – Dockerfile
# Builds static Expo web export and serves with nginx
# ─────────────────────────────────────────────────────────────────────────────

# Stage 1: Build
FROM node:20-alpine AS builder
WORKDIR /app

# Build args for env vars baked into the bundle
ARG EXPO_PUBLIC_API_URL=https://wimakit-api.fly.dev
ARG EXPO_PUBLIC_APP_NAME=WimaKit
ARG EXPO_PUBLIC_DEEP_LINK_SCHEME=wimakit

ENV EXPO_PUBLIC_API_URL=$EXPO_PUBLIC_API_URL
ENV EXPO_PUBLIC_APP_NAME=$EXPO_PUBLIC_APP_NAME
ENV EXPO_PUBLIC_DEEP_LINK_SCHEME=$EXPO_PUBLIC_DEEP_LINK_SCHEME

COPY package*.json ./
RUN npm ci

COPY . .
RUN npx expo export --platform web

# Stage 2: Serve with nginx
FROM nginx:alpine AS production
COPY --from=builder /app/dist /usr/share/nginx/html

# SPA config — redirect all routes to index.html
RUN printf 'server {\n\
  listen 3000;\n\
  root /usr/share/nginx/html;\n\
  index index.html;\n\
  gzip on;\n\
  gzip_types text/plain text/css application/json application/javascript text/xml application/xml;\n\
  location ~* \.(?:ico|css|js|gif|jpe?g|png|woff2?)$ {\n\
    expires 1y;\n\
    add_header Cache-Control "public, immutable";\n\
  }\n\
  location / {\n\
    try_files $uri $uri/ /index.html;\n\
  }\n\
}\n' > /etc/nginx/conf.d/default.conf

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
